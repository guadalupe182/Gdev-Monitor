#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

case "${1:-help}" in
    tv)
        bash "$ROOT_DIR/scripts/tv-mode.sh"
        ;;
    laptop)
        bash "$ROOT_DIR/scripts/laptop-mode.sh"
        ;;
    doctor)
        echo "Doctor mode (coming soon)"
        ;;
    status)
        echo "Status mode (coming soon)"
        ;;
    help|*)
        cat <<EOF
Gdev Monitor

Usage:

gdev tv
gdev laptop
gdev doctor
gdev status
EOF
        ;;
esac
